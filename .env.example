# ==============================================================================
# Configuración opcional — Plantilla TFG/TFM EPS UA
# ==============================================================================
#
# Este archivo es una PLANTILLA. Para usarlo:
#
#   1. Copia este archivo con el nombre  .env  (sin ".example")
#      En terminal:  cp .env.example .env
#      En Windows:   copy .env.example .env
#
#   2. Rellena los valores de las claves que quieras activar.
#      Las claves vacías (sin valor) se ignoran.
#
#   3. El archivo .env NO se sube a GitHub porque está en .gitignore.
#      Tus credenciales permanecen solo en tu ordenador.
#
# ==============================================================================


# ------------------------------------------------------------------------------
# COPYLEAKS — Detección de plagio y contenido generado por IA (opcional)
# ------------------------------------------------------------------------------
# Para qué sirve:
#   Envía tu documento a Copyleaks y muestra en el informe si hay indicios
#   de plagio o texto generado automáticamente por IA.
#
# Cómo obtener la clave (gratuito con cuenta básica):
#   1. Regístrate en https://copyleaks.com
#   2. Inicia sesión y ve a "Settings" → "API Access"
#   3. Copia tu email de cuenta y tu clave de API (UUID)
#
# Formato: tu-email@dominio.com:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Ejemplo: alumno@alu.ua.es:12345678-abcd-efgh-ijkl-000000000000
#
COPYLEAKS_API_KEY=


# ------------------------------------------------------------------------------
# TURNITIN — Detección de plagio con acceso institucional (opcional)
# ------------------------------------------------------------------------------
# ATENCIÓN: Turnitin requiere que tu universidad tenga contrato.
# Si no sabes si tu universidad lo tiene, pregunta en tu biblioteca.
#
# Clave de API (te la proporciona el servicio de tu institución):
TURNITIN_API_KEY=
#
# URL de tu institución en Turnitin:
# Ejemplo: https://ua.turnitin.com/api/v1
TURNITIN_TENANT_URL=
